{
  "files.associations": {
    "mkdocs.yml": "yaml"
  },
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    },
    "editor.formatOnSave": false
  },
  "[yaml]": {
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },
  "python.analysis.extraPaths": ["./scripts"],
  "files.exclude": {
    "**/__pycache__": true,
    "**/.venv": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "site": true
  },
  "search.exclude": {
    "**/.venv": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "site": true
  },
}